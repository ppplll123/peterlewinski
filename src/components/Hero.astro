---
import StatCounter from '../islands/StatCounter.tsx';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden noise-overlay">
  <!-- Dramatic gradient mesh background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-bg-primary"></div>
    <!-- Warm gold orb top-right -->
    <div class="parallax-slow absolute top-[10%] right-[15%] w-[600px] h-[500px] rounded-full bg-gold-500/[0.07] blur-[120px]"></div>
    <!-- Cool blue orb bottom-left -->
    <div class="parallax-slow absolute bottom-[20%] left-[10%] w-[500px] h-[400px] rounded-full bg-accent-blue/[0.06] blur-[100px]"></div>
    <!-- Central warm glow behind name -->
    <div class="parallax-slow absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[300px] bg-gold-500/[0.04] rounded-full blur-[80px]"></div>
    <!-- Subtle grid overlay -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(212,165,32,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(212,165,32,0.3) 1px, transparent 1px); background-size: 80px 80px;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-10 text-center pt-24 pb-16">
    <!-- Pre-title badge -->
    <div class="inline-flex items-center gap-2 mb-8 animate-fade-in">
      <span class="w-8 h-px bg-gold-500/40"></span>
      <span class="font-mono text-[10px] md:text-xs text-gold-500 tracking-[0.3em] uppercase">
        Dubai, UAE &nbsp;&middot;&nbsp; Warsaw, Poland
      </span>
      <span class="w-8 h-px bg-gold-500/40"></span>
    </div>

    <!-- Name — the hero moment -->
    <h1 class="font-display text-hero text-text-primary mb-6" style="animation: fadeIn 1s ease-out 0.2s both;">
      dr. Peter Lewinski<span class="text-gold-500">,</span><br class="md:hidden" /> EMBA
    </h1>

    <!-- Tagline -->
    <p class="text-subtitle text-text-secondary max-w-3xl mx-auto mb-5" style="animation: fadeIn 0.8s ease-out 0.5s both;">
      Ex-Professor &amp; Bank Director with 8 University Degrees
      in 4 Languages from 6 Countries
    </p>

    <!-- Credential chips -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-10" style="animation: fadeIn 0.8s ease-out 0.7s both;">
      {['PhD (Amsterdam)', 'MSc (Oxford)', 'EMBA (Chicago Booth)', 'Marie Curie Fellow', 'Judo Black Belt'].map((c) => (
        <span class="text-[11px] text-text-muted border border-subtle rounded-full px-3 py-1 font-mono tracking-wide">
          {c}
        </span>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex items-center justify-center gap-4 mb-12" style="animation: slideUp 0.8s ease-out 0.9s both;">
      <a href="#research" class="group inline-flex items-center gap-2 bg-gold-600 hover:bg-gold-500 text-bg-primary font-semibold text-sm rounded-lg px-6 py-3 transition-all hover:shadow-[0_0_30px_rgba(212,165,32,0.2)]">
        View Publications
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-y-0.5 transition-transform"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </a>
      <a href="/evidence/cv-peter-lewinski.pdf" class="inline-flex items-center gap-2 border border-subtle-strong hover:border-gold-500/40 text-text-primary text-sm rounded-lg px-6 py-3 transition-all hover:bg-bg-card">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Download CV
      </a>
    </div>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-5 mb-16" style="animation: fadeIn 0.8s ease-out 1.1s both;">
      <a href="https://www.linkedin.com/in/peterlewinski-phd" target="_blank" rel="noopener" class="text-text-muted hover:text-gold-500 transition-colors duration-300" title="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://scholar.google.com/citations?user=EzMytF4AAAAJ" target="_blank" rel="noopener" class="text-text-muted hover:text-gold-500 transition-colors duration-300" title="Google Scholar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
      </a>
      <a href="https://www.instagram.com/lewinski.peter/" target="_blank" rel="noopener" class="text-text-muted hover:text-gold-500 transition-colors duration-300" title="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://github.com/ppplll123" target="_blank" rel="noopener" class="text-text-muted hover:text-gold-500 transition-colors duration-300" title="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a href="https://chatgptleads.page/peter" target="_blank" rel="noopener" class="text-text-muted hover:text-gold-500 transition-colors duration-300" title="ChatGPT Leads">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729z"/></svg>
      </a>
    </div>

    <!-- Stats bar — the showstopper -->
    <div class="relative rounded-xl overflow-hidden" style="animation: slideUp 1s ease-out 1.3s both;">
      <!-- Gradient border effect -->
      <div class="absolute inset-0 rounded-xl p-px bg-gradient-to-r from-gold-500/30 via-gold-500/5 to-gold-500/30">
        <div class="w-full h-full rounded-xl bg-bg-card/90 backdrop-blur-md"></div>
      </div>
      <div class="relative grid grid-cols-3 md:grid-cols-6 gap-0 divide-x divide-gold-500/10">
        <StatCounter client:visible end={10} label="Companies" sublabel="helped build" />
        <StatCounter client:visible end={12} label="Deep Tech" sublabel="products scaled" />
        <StatCounter client:visible end={1} prefix="€" suffix="M" label="Sold" sublabel="personally in 12mo" />
        <StatCounter client:visible end={6} suffix="x" label="Founder" sublabel="deep tech startups" />
        <StatCounter client:visible end={2300} suffix="+" label="Cited" sublabel="Google Scholar" />
        <div class="text-center px-3 py-5">
          <div class="font-display text-xl md:text-2xl font-semibold text-gold-gradient mb-1"
               style="background: linear-gradient(135deg, #D4A520, #F2DFA7, #D4A520); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            PhD &amp; Prof
          </div>
          <div class="text-xs md:text-sm font-medium text-text-primary uppercase tracking-wider">
            Postdoc
          </div>
          <div class="text-[10px] md:text-xs text-text-muted mt-0.5">
            Oxford MSc &middot; Booth EMBA
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-14 animate-float opacity-25">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-gold-500">
        <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
      </svg>
    </div>
  </div>
</section>

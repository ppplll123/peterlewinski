---
import SectionTitle from './ui/SectionTitle.astro';
import EvidenceLink from './ui/EvidenceLink.astro';
import publications from '../data/publications.json';
---

<section id="research" class="py-section px-6 md:px-10 max-w-5xl mx-auto relative section-glow">
  <SectionTitle title="Research" />

  <!-- Intro -->
  <div class="mb-12 text-text-secondary leading-relaxed max-w-3xl reveal">
    <p class="mb-4">PhD, ex-Postdoc, and ex-tenure-track Professor in Marketing from top universities in the UK, USA, and EU, including the University of Oxford. Expertise in the top 1 (QS World Ranking) marketing department and M7 Executive MBA (Chicago Booth).</p>
    <p>20 widely-cited peer-reviewed publications in top journals, accounting for 60% of citations in a specific marketing niche, cited 2,300+ times on Google Scholar. Peer-reviewed 40+ papers, edited dozens of others, and presented at 25+ international conferences.</p>
  </div>

  <!-- Metrics — stat pills -->
  <div class="grid grid-cols-3 md:grid-cols-6 gap-3 mb-14 reveal-stagger">
    {[
      { value: '2,304', label: 'Citations' },
      { value: '21', label: 'H-Index' },
      { value: '20', label: 'Publications' },
      { value: '33.49', label: 'Cumulative IF' },
      { value: '29', label: 'i10-Index' },
      { value: '40+', label: 'Papers Reviewed' },
    ].map((m) => (
      <div class="stat-pill">
        <div class="font-display text-2xl font-semibold text-gold-gradient" style="background: linear-gradient(135deg, #D4A520, #F2DFA7, #D4A520); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          {m.value}
        </div>
        <div class="text-[10px] text-text-muted uppercase tracking-wider mt-1.5">{m.label}</div>
      </div>
    ))}
  </div>

  <!-- Publications list -->
  <div class="space-y-3 reveal">
    {publications.map((pub: any) => (
      <a href={pub.url} target="_blank" rel="noopener"
         class="block card-glass rounded-xl p-5 group pub-row">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="text-sm md:text-base font-medium text-text-primary mb-1 leading-snug group-hover:text-champagne transition-colors">{pub.title}</h3>
            <p class="text-xs text-text-muted">{pub.authors}</p>
            <p class="text-xs text-text-muted mt-1">
              <span class="italic">{pub.journal}</span>, {pub.year}
            </p>
          </div>
          <div class="flex-shrink-0 text-right">
            <div class="font-mono text-xl font-semibold text-gold-500">{pub.citations}</div>
            <div class="text-[9px] text-text-muted uppercase tracking-wider">citations</div>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Links -->
  <div class="mt-8 flex flex-wrap gap-4 reveal">
    <EvidenceLink href="https://scholar.google.com/citations?user=EzMytF4AAAAJ" label="Google Scholar" />
    <EvidenceLink href="https://www.researchgate.net/profile/Peter-Lewinski" label="ResearchGate" />
    <EvidenceLink href="https://www.semanticscholar.org/author/Peter-Lewinski/6402753" label="Semantic Scholar" />
    <EvidenceLink href="https://cordis.europa.eu/project/id/290255" label="Marie Curie Grant (CORDIS)" />
    <EvidenceLink href="https://www.adscientificindex.com/scientist/peter-lewinski-llm/1041397" label="AD Scientific Index" />
  </div>

  <!-- Awards — 4 total (was 2, added Frontiers + EFPSA) -->
  <div class="mt-14 grid md:grid-cols-2 gap-4 reveal-stagger">
    <div class="card-glass rounded-xl p-5 gradient-border">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Fellowship</div>
      <h3 class="font-display text-lg text-text-primary mb-1">Marie Skłodowska-Curie Fellow</h3>
      <p class="text-xs text-text-secondary">European Commission, CONCORT network (&euro;265k grant). Partners: INSEAD, London Business School, Philips, Unilever, ESMT, Tobii AB.</p>
    </div>
    <div class="card-glass rounded-xl p-5 gradient-border">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Award</div>
      <h3 class="font-display text-lg text-text-primary mb-1">NMSBA Neurotalent of the Year</h3>
      <p class="text-xs text-text-secondary">Neuromarketing Science & Business Association, 2013/2014. Recognized for pioneering work in automated facial coding validation.</p>
    </div>
    <div class="card-glass rounded-xl p-5 gradient-border">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Editorial</div>
      <h3 class="font-display text-lg text-text-primary mb-1">Frontiers Guest Associate Editor</h3>
      <p class="text-xs text-text-secondary">2014&ndash;2024. Peer-reviewed and edited for Frontiers in Psychology and Frontiers in Neuroscience.</p>
      <div class="mt-2"><EvidenceLink href="https://loop.frontiersin.org/people/175740/editorial" label="Frontiers Loop" /></div>
    </div>
    <div class="card-glass rounded-xl p-5 gradient-border">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Leadership</div>
      <h3 class="font-display text-lg text-text-primary mb-1">EFPSA Executive Board & CFO</h3>
      <p class="text-xs text-text-secondary">2011&ndash;2013. Secured grants from the European Commission and Council of Europe. Managed budget for Europe-wide psychology student federation.</p>
    </div>
  </div>
</section>

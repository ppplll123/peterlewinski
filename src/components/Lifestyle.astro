---
import SectionTitle from './ui/SectionTitle.astro';
import travel from '../data/travel.json';
---

<section id="lifestyle" class="py-section relative overflow-hidden">
  <!-- Full-bleed dark background -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg-secondary via-bg-primary to-bg-primary"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/20 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/20 to-transparent"></div>
<div class="relative max-w-6xl mx-auto px-6 md:px-10">
  <SectionTitle title="315+ Nights. 6 Continents." subtitle="2025 travel stats and loyalty program statuses." />

  <!-- Hotel statuses -->
  <h3 class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-6 reveal">Hotel Loyalty Statuses</h3>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-14 reveal-stagger">
    {travel.hotels.map((h: any) => (
      <div class="card-glass rounded-xl p-5 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-1 h-full" style={`background: ${h.color}; box-shadow: 0 0 12px ${h.color}40;`}></div>
        <div class="pl-3">
          <div class="text-xs text-text-muted mb-1">{h.program}</div>
          <div class="font-display text-lg font-semibold text-text-primary group-hover:text-champagne transition-colors">{h.status}</div>
          <div class="text-[11px] text-text-muted mt-1">{h.detail}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Airline statuses -->
  <h3 class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-6 reveal">Airline Loyalty Statuses</h3>
  <div class="grid md:grid-cols-3 gap-3 mb-14 reveal-stagger">
    {travel.airlines.map((a: any) => (
      <div class="card-glass rounded-xl p-5 relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-1 h-full" style={`background: ${a.color}; box-shadow: 0 0 12px ${a.color}40;`}></div>
        <div class="pl-3">
          <div class="text-xs text-text-muted mb-1">{a.program}</div>
          <div class="font-display text-lg font-semibold text-text-primary group-hover:text-champagne transition-colors">{a.status}</div>
          <div class="text-xs text-gold-500/60 mt-1">{a.alliance}</div>
          <div class="text-[10px] text-text-muted mt-1">{a.carriers}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Travel credentials -->
  <h3 class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-4 reveal">Travel Credentials</h3>
  <div class="flex flex-wrap gap-2 reveal">
    {travel.credentials.map((c: string) => (
      <span class="text-xs text-text-secondary bg-bg-elevated/50 border border-subtle rounded-full px-4 py-1.5 font-mono">
        {c}
      </span>
    ))}
  </div>

  <!-- Screenshot placeholders -->
  <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-3 reveal-stagger">
    {['Hyatt Globalist', 'Marriott Ambassador', 'Airlines Status', 'Hotels Overview'].map((label) => (
      <div class="card-glass rounded-xl aspect-[9/16] flex items-center justify-center border-dashed border border-gold-500/10">
        <div class="text-center">
          <div class="text-2xl opacity-20 mb-2">📱</div>
          <p class="text-text-muted text-[10px]">{label}</p>
        </div>
      </div>
    ))}
  </div>
</div>
</section>

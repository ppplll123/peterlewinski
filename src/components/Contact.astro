---
import SectionTitle from './ui/SectionTitle.astro';
---

<section id="contact" class="py-section px-6 md:px-10 max-w-4xl mx-auto relative section-glow">
  <SectionTitle title="Let's Talk" align="center" />

  <div class="grid md:grid-cols-2 gap-10 reveal">
    <!-- Contact info -->
    <div class="space-y-7">
      <div>
        <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Email</div>
        <a href="mailto:peter.lewinski@gmail.com" class="text-text-primary hover:text-champagne transition-colors text-sm">
          peter.lewinski@gmail.com
        </a>
      </div>
      <div>
        <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Phone</div>
        <p class="text-text-secondary text-sm">+971 58 583 5930 (Dubai)</p>
        <p class="text-text-secondary text-sm">+48 518 399 335 (Warsaw)</p>
      </div>
      <div>
        <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Location</div>
        <p class="text-text-secondary text-sm">Dubai, UAE &middot; Warsaw, Poland</p>
      </div>
      <div>
        <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-2">Links</div>
        <div class="flex flex-col gap-1.5">
          <a href="https://www.linkedin.com/in/peterlewinski-phd" target="_blank" class="text-sm text-text-secondary hover:text-champagne transition-colors gold-underline">LinkedIn</a>
          <a href="https://scholar.google.com/citations?user=EzMytF4AAAAJ" target="_blank" class="text-sm text-text-secondary hover:text-champagne transition-colors gold-underline">Google Scholar</a>
          <a href="https://chatgptleads.page/peter" target="_blank" class="text-sm text-text-secondary hover:text-champagne transition-colors gold-underline">ChatGPT Leads</a>
          <a href="https://www.instagram.com/lewinski.peter/" target="_blank" class="text-sm text-text-secondary hover:text-champagne transition-colors gold-underline">Instagram</a>
        </div>
      </div>
    </div>

    <!-- Contact form -->
    <form
      action="https://formspree.io/f/YOUR_FORM_ID"
      method="POST"
      class="space-y-4"
    >
      <div>
        <label for="name" class="block text-[10px] text-text-muted uppercase tracking-[0.15em] mb-1.5 font-mono">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full bg-bg-card/80 border border-subtle rounded-lg px-4 py-3 text-sm text-text-primary placeholder:text-text-muted/30 focus:outline-none focus:border-gold-500/30 focus:shadow-[0_0_20px_rgba(212,165,32,0.05)] transition-all"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="block text-[10px] text-text-muted uppercase tracking-[0.15em] mb-1.5 font-mono">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full bg-bg-card/80 border border-subtle rounded-lg px-4 py-3 text-sm text-text-primary placeholder:text-text-muted/30 focus:outline-none focus:border-gold-500/30 focus:shadow-[0_0_20px_rgba(212,165,32,0.05)] transition-all"
          placeholder="you@example.com"
        />
      </div>
      <div>
        <label for="message" class="block text-[10px] text-text-muted uppercase tracking-[0.15em] mb-1.5 font-mono">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full bg-bg-card/80 border border-subtle rounded-lg px-4 py-3 text-sm text-text-primary placeholder:text-text-muted/30 focus:outline-none focus:border-gold-500/30 focus:shadow-[0_0_20px_rgba(212,165,32,0.05)] transition-all resize-none"
          placeholder="Your message..."
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full bg-gold-600 hover:bg-gold-500 text-bg-primary font-semibold text-sm rounded-lg px-6 py-3.5 transition-all uppercase tracking-[0.15em] hover:shadow-[0_0_30px_rgba(212,165,32,0.2)]"
      >
        Send Message
      </button>
    </form>
  </div>
</section>

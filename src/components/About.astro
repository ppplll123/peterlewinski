---
import SectionTitle from './ui/SectionTitle.astro';
---

<section id="about" class="py-section px-6 md:px-10 max-w-7xl mx-auto relative section-glow">
  <SectionTitle title="The Intersection" subtitle="A rare combination of academic depth, institutional credibility, and entrepreneurial execution." />

  <div class="grid md:grid-cols-3 gap-5 md:gap-6 mb-16 reveal-stagger">
    <!-- Academic — staggered offset -->
    <div class="card-glass rounded-xl p-6 md:p-8 gold-left-accent md:mt-0">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-5 pl-1">Academic</div>
      <ul class="space-y-3.5 text-sm text-text-secondary">
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>PhD, Behavioral Science <span class="text-text-muted">(University of Amsterdam)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>MSc, Law & Finance <span class="text-text-muted">(University of Oxford)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Executive MBA <span class="text-text-muted">(Chicago Booth)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Marie Curie Fellow <span class="text-text-muted">(&euro;265k EU grant)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Assistant Professor <span class="text-text-muted">(Kozminski)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span class="text-champagne">2,300+ citations, H-Index: 21</span>
        </li>
      </ul>
    </div>

    <!-- Enterprise — offset down -->
    <div class="card-glass rounded-xl p-6 md:p-8 gold-left-accent md:mt-10">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-5 pl-1">Enterprise</div>
      <ul class="space-y-3.5 text-sm text-text-secondary">
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Deputy Director, Credit Risk <span class="text-text-muted">at ING Bank</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span class="text-champagne">&euro;19.2bn loan portfolio oversight</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>60 regulatory-compliant risk models</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Fintech SPOC <span class="text-text-muted">for 300-person Risk unit</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Board presenter <span class="text-text-muted">(top 150 managers)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>AI deployed to <span class="text-champagne">6 national tax agencies</span></span>
        </li>
      </ul>
    </div>

    <!-- Entrepreneur — offset more -->
    <div class="card-glass rounded-xl p-6 md:p-8 gold-left-accent md:mt-20">
      <div class="font-mono text-[10px] text-gold-500 tracking-[0.2em] uppercase mb-5 pl-1">Entrepreneur</div>
      <ul class="space-y-3.5 text-sm text-text-secondary">
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>CEO & Founder, ChatGPT Leads <span class="text-champagne">($0.5M+/yr)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>CEO, Sentient Machine Research Group</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>Co-founder, FaceReader Online <span class="text-text-muted">(1,000+ users)</span></span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span class="text-champagne">40% CAGR turnaround</span> <span class="text-text-muted">(&euro;1M&rarr;&euro;2M)</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>&euro;40M+ in pre-sold AI projects</span>
        </li>
        <li class="flex items-start gap-2.5">
          <span class="text-gold-500 mt-0.5 text-[8px]">&#9670;</span>
          <span>$350k&rarr;$1.1M p.m. <span class="text-text-muted">(Salesprocess.io)</span></span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Pull quote -->
  <blockquote class="max-w-3xl mx-auto text-center reveal relative">
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 text-gold-500/20 font-display text-6xl">&ldquo;</div>
    <p class="font-display text-xl md:text-2xl text-text-primary leading-relaxed italic pt-6">
      I finished my PhD by age 25 with 3x publications vs. the average, while working full-time, pursuing a 2nd bachelor&rsquo;s degree, and being happily married.
    </p>
  </blockquote>
</section>

---
const year = new Date().getFullYear();
---

<footer class="border-t border-subtle py-12 px-6 md:px-10 relative">
  <!-- Subtle glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] h-[100px] bg-gold-500/[0.02] rounded-full blur-[60px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-5">
    <div class="font-display text-sm text-text-muted">
      &copy; {year} dr. Peter Lewinski, EMBA
    </div>
    <div class="flex items-center gap-7 text-xs text-text-muted">
      <a href="https://www.linkedin.com/in/peterlewinski-phd" target="_blank" class="hover:text-gold-500 transition-colors duration-300">LinkedIn</a>
      <a href="https://scholar.google.com/citations?user=EzMytF4AAAAJ" target="_blank" class="hover:text-gold-500 transition-colors duration-300">Scholar</a>
      <a href="https://www.instagram.com/lewinski.peter/" target="_blank" class="hover:text-gold-500 transition-colors duration-300">Instagram</a>
      <a href="https://github.com/ppplll123" target="_blank" class="hover:text-gold-500 transition-colors duration-300">GitHub</a>
    </div>
    <div class="text-[10px] text-text-muted/40 font-mono tracking-wider">
      Dubai &middot; Warsaw
    </div>
  </div>
</footer>

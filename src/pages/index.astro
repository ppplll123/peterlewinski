---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Transformations from '../components/Transformations.astro';
import Career from '../components/Career.astro';
import Research from '../components/Research.astro';
import Education from '../components/Education.astro';
import Sports from '../components/Sports.astro';
import Lifestyle from '../components/Lifestyle.astro';
import Watches from '../components/Watches.astro';
import Cars from '../components/Cars.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <!-- CREAM: About — warm contrast after dark hero -->
    <div class="section-cream">
      <About />
    </div>
    <!-- DARK: Transformations -->
    <div class="section-lighter">
      <Transformations />
    </div>
    <!-- CREAM: Career — warm, readable -->
    <div class="section-cream">
      <Career />
    </div>
    <!-- DARK: Research -->
    <div class="section-navy">
      <Research />
    </div>
    <!-- CREAM: Education -->
    <div class="section-cream">
      <Education />
    </div>
    <!-- DARK: Sports — dramatic -->
    <div class="section-dark">
      <Sports />
    </div>
    <!-- DARK: Lifestyle — dark with neon accents -->
    <Lifestyle />
    <!-- CREAM: Watches -->
    <div class="section-cream">
      <Watches />
    </div>
    <!-- DARK: Cars -->
    <div class="section-dark">
      <Cars />
    </div>
    <!-- DARK: Contact -->
    <Contact />
  </main>
  <Footer />
</Layout>
